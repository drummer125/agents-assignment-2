# ============================================================================
# CRITICAL: Secrets and credentials — NEVER commit these
# ============================================================================

# Environment files with API keys, tokens
.env
.env.local
.env.*.local
*.env

# OAuth credentials and cached tokens (Google Calendar)
credentials/
credentials.json
token.json
token.pickle
*credentials*.json
*token*.json

# GitHub Personal Access Tokens leaked into any file (defense in depth)
*_pat_*.txt
*ghp_*.txt

